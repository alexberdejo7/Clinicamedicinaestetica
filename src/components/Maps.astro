---
// Ubicacion.astro
---

<section id="ubicacion" class="bg-gray-50 py-16 px-4 sm:px-6 ">
  <div class="mx-auto max-w-5xl">

    <p class="text-xs uppercase tracking-widest text-nude-clinica font-poppins mb-2">
      Encuéntranos
    </p>
    <h2 class="text-3xl md:text-4xl font-neoteric text-nude-text mb-2">
      Nuestra <span class="text-nude-clinica">ubicación</span> y horarios
    </h2>
    <div class="w-10 h-0.5 bg-nude-clinica rounded mb-10"></div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <!-- Columna izquierda: mapa + dirección -->
      <div class="flex flex-col gap-4">

        <!-- Mapa -->
        <div class="w-full h-60 rounded-xl overflow-hidden shadow-sm border border-nude-clinica/20">
          <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d30196.870880782328!2d-99.21730147840991!3d18.904425664064167!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85cddf004c13ea5f%3A0x43db245383a0a3a4!2sCl%C3%ADnica%20de%20medicina%20est%C3%A9tica%20Dra.%20Jessica%20Alcal%C3%A1!5e0!3m2!1ses-419!2s!4v1776010976848!5m2!1ses-419!2s" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>

        <!-- Tarjeta dirección -->
        <div class="bg-white/70 backdrop-blur-sm rounded-xl p-5 shadow-sm border border-nude-clinica/10">
          <p class="text-[11px] uppercase tracking-widest text-nude-clinica font-poppins mb-3">
            Dirección
          </p>
          <div class="flex items-start gap-3">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-nude-clinica" viewBox="0 0 16 16" fill="none">
              <path d="M8 1.5a4.5 4.5 0 0 0-4.5 4.5c0 3 4.5 8.5 4.5 8.5s4.5-5.5 4.5-8.5A4.5 4.5 0 0 0 8 1.5z" stroke="currentColor" stroke-width="1.3"/>
              <circle cx="8" cy="6" r="1.5" stroke="currentColor" stroke-width="1.3"/>
            </svg>
            <div>
              <p class="text-sm font-poppins text-nude-text leading-relaxed">
                Av. 10 de Abril #6, esquina Vicente Guerrero
              </p>
              <p class="text-xs font-poppins text-nude-text/60 mt-0.5">
                Col. Granjas · Cuernavaca, Morelos · C.P. 62460
              </p>
            </div>
          </div>

          
            <a href="https://www.google.com/maps/search/Av+10+de+Abril+6+esquina+Vicente+Guerrero+Granjas+Cuernavaca+Morelos"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-nude-text text-white text-xs font-poppins hover:opacity-80 transition-opacity no-underline"
          >
            Abrir en Google Maps
            <span>→</span>
          </a>
        </div>
      </div>

      <!-- Columna derecha: horarios -->
      <div class="bg-white/70 backdrop-blur-sm rounded-xl p-5 shadow-sm border border-nude-clinica/10 h-fit">
        <p class="text-[11px] uppercase tracking-widest text-nude-clinica font-poppins mb-4">
          Horario de atención
        </p>

        <ul class="divide-y divide-nude-clinica/10">
          {[
            { dia: "Lunes",   hora: "10:00 am – 4:00 pm" },
            { dia: "Martes",  hora: "10:00 am – 4:00 pm" },
            { dia: "Viernes", hora: "10:00 am – 4:00 pm" },
            { dia: "Sábado",  hora: "10:00 am – 4:00 pm" },
          ].map(({ dia, hora }) => (
            <li class="flex justify-between items-center py-3">
              <span class="text-sm font-poppins font-medium text-nude-text">{dia}</span>
              <span class="text-xs font-poppins text-nude-text/60">{hora}</span>
              <span class="text-[11px] px-3 py-1 rounded-full font-poppins bg-green-50 text-green-700">
                Abierto
              </span>
            </li>
          ))}
        </ul>

        
      </div>

    </div>
  </div>
</section>