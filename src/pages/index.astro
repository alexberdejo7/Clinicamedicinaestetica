---
import Layout from '../layouts/MainLayout.astro';
import HeroTest5 from '../components/HeroTest5.astro';
import Services from '../components/Services.astro';
import Aboutus from '../components/Aboutus.astro';
import Course from '../components/Course.astro';
import Feature from '../components/Feature.astro';
import Frase from '../components/Frase.astro';
import Testimonios from '../components/Testimonios.astro';
import Maps from '../components/Maps.astro'
import New from '../components/New.astro'

import 'aos/dist/aos.css';
---



<New/>


<script>
  // Inicializar AOS de manera diferida
  window.addEventListener('load', () => {
    if (typeof window !== 'undefined') {
      import('aos').then(AOS => {
        AOS.init();
      });
    }
  });
</script>


